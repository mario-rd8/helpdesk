# ==============================================================================
# MVP Help Desk Selfware — Juntos Educação
# Variáveis de Ambiente
# ==============================================================================
# Copie este arquivo para .env e preencha com suas credenciais reais.
# NUNCA versione o arquivo .env no repositório!
# ==============================================================================

# ------------------------------------------------------------------------------
# Banco de Dados PostgreSQL (Conexão Direta — Supabase)
# ------------------------------------------------------------------------------
DB_HOST=db.xxxxxxxxxxxxx.supabase.co
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=sua-senha-do-supabase
DB_NAME=postgres

# ------------------------------------------------------------------------------
# API do Supabase (Acesso via REST / Client JS)
# ------------------------------------------------------------------------------
SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxx...
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxx...

# ------------------------------------------------------------------------------
# Evolution API (Integração WhatsApp)
# ------------------------------------------------------------------------------
EVOLUTION_API_URL=https://evolution.seudominio.com.br
EVOLUTION_API_KEY=sua-api-key-da-evolution
EVOLUTION_INSTANCE_NAME=helpdesk-juntos

# ------------------------------------------------------------------------------
# Telegram Bot (Alertas para Técnicos)
# ------------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=0000000000:XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TELEGRAM_WEBHOOK_URL=https://n8n.seudominio.com.br/webhook/telegram

# ------------------------------------------------------------------------------
# n8n (Orquestração de Automações)
# ------------------------------------------------------------------------------
N8N_BASE_URL=https://n8n.seudominio.com.br
N8N_API_KEY=sua-api-key-do-n8n

# ------------------------------------------------------------------------------
# Coolify (Hospedagem Self-Hosted)
# ------------------------------------------------------------------------------
COOLIFY_URL=https://coolify.seudominio.com.br
COOLIFY_API_TOKEN=seu-token-do-coolify
